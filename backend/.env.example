# CoLab — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Paths (defaults work out of the box)
DATA_DIR=./data
DATACUBE_DIR=./datacubes

# LLM via OpenRouter (https://openrouter.ai)
# Leave blank to use rule-based fallback (no LLM required)
OPENROUTER_API_KEY=

# Embedding model used for semantic search
EMBEDDING_MODEL=all-MiniLM-L6-v2

OLLAMA_MODEL=llama3.2:3b

# Set to True to include LLM reasoning in recommendation results
REASONING=True
